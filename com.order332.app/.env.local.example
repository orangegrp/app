# ── JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=change_me_min_32_chars_replace_with_random_hex
JWT_REFRESH_SECRET=change_me_min_32_chars_different_from_above
# Separate secret for Discord account-linking tokens — prevents token confusion with access tokens
DISCORD_LINK_SECRET=change_me_min_32_chars_different_from_above

# ── QR code encryption key (must be exactly 32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_ENCRYPTION_KEY=change_me_must_be_exactly_64_hex_chars_00000000000000000000000000

# ── Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# ── Bot secret — shared only with the trusted Discord bot
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BOT_SECRET=change_me_min_32_chars_replace_with_random_hex

# ── Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase direct PostgreSQL connection (for schema management)
# Find in: Supabase Dashboard → Project Settings → Database → Connection string → URI (use Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── App (use the exact browser origin; required for WebAuthn/passkeys — e.g. https://your-host.ts.net when dev over Tailscale)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=dev

# ── Dev login bypass (both vars required; never set in production)
# DEV_LOGIN_ENABLED=true
# NEXT_PUBLIC_DEV_LOGIN_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Cloudflare R2 (WebPC disk images — server-only; never expose to the client bundle)
#
# Operations checklist (presigned GET must match Cloudflare / aws s3 presign):
# - R2 API token: Object Read (or Read & Write), scoped to this bucket — account-wide-only tokens are not sufficient.
# - R2_ACCOUNT_ID must match Cloudflare Dashboard exactly (32-char hex).
# - Verify outside the app: aws s3 ls s3://<R2_BUCKET_NAME>/ --endpoint-url https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
#   and aws s3 presign s3://<bucket>/webpc-images/<file>.ext2 --endpoint-url ... --expires-in 3600
#
# Presigned URLs use https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com only (not custom public domains).
# Default URL shape is path-style: /<bucket>/webpc-images/<file>.ext2 — same as AWS CLI presign with that endpoint.
# Set R2_FORCE_PATH_STYLE=false only if you need virtual-hosted URLs (bucket as subdomain).
#
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=s3-app-order332
# R2_KEY_PREFIX=webpc-images/
# R2_FORCE_PATH_STYLE=false

# ── GitHub Blog CMS (server-only — never expose to client bundle)
# Fine-grained PAT with Contents read+write on orangegrp/website
GITHUB_TOKEN=ghp_...
GITHUB_BLOG_REPO=orangegrp/website
GITHUB_BLOG_BRANCH=main
GITHUB_BLOG_PATH=/com.order332/src/content/blog
