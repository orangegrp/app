# ── JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=change_me_min_32_chars_replace_with_random_hex
JWT_REFRESH_SECRET=change_me_min_32_chars_different_from_above
# Separate secret for Discord account-linking tokens — prevents token confusion with access tokens
DISCORD_LINK_SECRET=change_me_min_32_chars_different_from_above

# ── QR code encryption key (must be exactly 32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_ENCRYPTION_KEY=change_me_must_be_exactly_64_hex_chars_00000000000000000000000000

# ── Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# ── Bot secret — shared only with the trusted Discord bot
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BOT_SECRET=change_me_min_32_chars_replace_with_random_hex

# ── Vercel Cron — at least 16 chars; Vercel sends Authorization: Bearer <CRON_SECRET> for scheduled jobs
# CRON_SECRET=your_random_cron_secret_here

# ── Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase direct PostgreSQL connection (for schema management)
# Find in: Supabase Dashboard → Project Settings → Database → Connection string → URI (use Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── App (use the exact browser origin; required for WebAuthn/passkeys — e.g. https://your-host.ts.net when dev over Tailscale)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=dev
# Disable Vercel BotId (local / Tailscale / non-Vercel OIDC). Set before build if you need it in production images; never set in production unless intentional.
# DISABLE_BOT_ID=true

# ── Dev login bypass (both vars required; never set in production)
# DEV_LOGIN_ENABLED=true
# NEXT_PUBLIC_DEV_LOGIN_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Cloudflare R2 (WebPC + music assets — server-only; never expose to the client bundle)
#
# One bucket (e.g. s3-app-order332): WebPC VM disks under R2_KEY_PREFIX, music under MUSIC_R2_KEY_PREFIX
# (logical keys in Postgres stay audio/…, covers/…, lyrics/… — full R2 key = prefix + that path).
#
# API token: scoped to the bucket. WebPC only needs read; music also needs write + delete (uploads, track delete).
# Account-wide-only tokens are not sufficient.
# R2_ACCOUNT_ID must match Cloudflare Dashboard (32-char hex).
#
# Verify: aws s3 ls s3://<R2_BUCKET_NAME>/ --endpoint-url https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# Presigned URLs use the S3 API hostname (not custom R2 public domains). See WebPC + Cloudflare R2 presign docs.
#
# Browser uploads (XHR/fetch PUT to a presigned URL) require a CORS policy on the bucket or they fail
# preflight. Cloudflare dashboard: R2 → bucket → Settings → CORS Policy → JSON. See r2-bucket-cors.example.json
# in this app; AllowedOrigins must include every origin you use (e.g. http://localhost:3000, your production
# URL, Tailscale dev URLs like https://host.ts.net). Replace placeholder entries, then Save. Propagation can
# take up to ~30s.
#
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=s3-app-order332
# R2_KEY_PREFIX=webpc-images/
# MUSIC_R2_KEY_PREFIX=music-tracks/
# R2_FORCE_PATH_STYLE=false

# ── Vercel AI Gateway (server-only — blog AI assist; never expose to client)
# https://vercel.com/docs/ai-gateway
# AI_GATEWAY_API_KEY=

# ── GitHub Blog CMS (server-only — never expose to client bundle)
# Fine-grained PAT with Contents read+write on orangegrp/website
GITHUB_TOKEN=ghp_...
GITHUB_BLOG_REPO=orangegrp/website
GITHUB_BLOG_BRANCH=main
GITHUB_BLOG_PATH=/com.order332/src/content/blog

# ── VirusTotal (server-only — content library malware scanning)
# API v3 key from https://www.virustotal.com/gui/my-apikey
# If not set, VT scanning is silently skipped (uploads still work).
# VIRUSTOTAL_API_KEY=
